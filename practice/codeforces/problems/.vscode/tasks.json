{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "g++: build active file",
      "type": "shell",
      "command": "D:/VSCODE/TDM-GCC-64/bin/g++.exe",
      "args": [
        "-g",
        "-O2",
        "-std=c++17",
        "${file}",
        "-o",
        "${fileDirname}\\build\\Debug\\outDebug.exe"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "reveal": "silent"
      }
    }
  ]
}
